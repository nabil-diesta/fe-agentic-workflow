# Copy to .env and fill in. Never commit .env.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_SMART_MODEL=gpt-4.1
TELEGRAM_BOT_TOKEN=
AGENT_NAME=DevAgent
CHROMA_PERSIST_PATH=./data/chroma
SQLITE_PATH=./data/agent.db
# Laptop listener (SSH tunnel: localhost:4000 on VPS → laptop)
LAPTOP_LISTENER_URL=http://localhost:4000

# Jira (direct API fallback when listener is offline)
JIRA_API_TOKEN=
